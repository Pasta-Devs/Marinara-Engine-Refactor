{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "src/app/**/*.{ts,tsx}",
    "src/shared/api/**/*.{ts,tsx}",
    "vite.config.ts",
    "eslint.config.js",
    "playwright.config.ts",
    "vitest.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.mjs",
    "*.config.{js,ts}",
    ".dependency-cruiser.cjs"
  ],
  "ignore": [
    "dist/**",
    "docs/**",
    "src-tauri/**",
    "public/**"
  ]
}
